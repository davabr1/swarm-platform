// Swarm schema — Supabase Postgres
// Mirrors the in-memory shape today (AgentListing, TaskPosting, activityLog)
// so route handlers stay thin and serializeAgent keeps working unchanged.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agent {
  id              String   @id
  name            String
  skill           String
  description     String
  price           String
  walletAddress   String
  creatorAddress  String?
  systemPrompt    String?
  type            String
  userCreated     Boolean  @default(false)
  agentId         String?
  reputation      Float    @default(0)
  ratingsCount    Int      @default(0)
  totalCalls      Int      @default(0)
  pricingModel    String?
  pricingNote     String?
  createdAt       DateTime @default(now())

  @@index([type])
  @@index([userCreated])
  @@index([reputation(sort: Desc)])
}

model Task {
  id             String    @id
  description    String
  bounty         String
  skill          String
  payload        String?
  status         String    @default("open")
  postedBy       String?
  claimedBy      String?
  result         String?
  assignedTo     String?
  requiredSkill  String?
  minReputation  Float?
  visibility     String    @default("private")
  posterRating   Int?
  posterRatedAt  DateTime?
  createdAt      DateTime  @default(now())
  claimedAt      DateTime?
  completedAt    DateTime?

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([assignedTo])
  @@index([requiredSkill])
}

model Activity {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  timestamp BigInt

  @@index([timestamp(sort: Desc)])
}

model UserProfile {
  walletAddress      String   @id
  displayName        String?
  bio                String?
  email              String?
  spendCapPerTask    String?
  spendCapPerSession String?
  autoTopup          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model GuidanceRequest {
  id             String    @id
  agentId        String
  askerAddress   String
  question       String
  status         String    @default("pending")
  response       String?
  errorMessage   String?
  commissionUsd  String?
  geminiCostUsd  String?
  platformFeeUsd String?
  totalUsd       String?
  promptTokens   Int?
  outputTokens   Int?
  thoughtsTokens Int?
  replyType      String?
  parentId       String?
  rootId         String?
  createdAt      DateTime  @default(now())
  readyAt        DateTime?

  @@index([agentId])
  @@index([askerAddress])
  @@index([rootId])
}

model ImageGeneration {
  id             String    @id
  agentId        String
  askerAddress   String
  prompt         String
  status         String    @default("pending")
  imageUrl       String?
  // Base64-encoded PNG/JPEG bytes. Stored in Postgres so we can serve the
  // image via GET /api/image/[id] — Vercel's filesystem is read-only so we
  // can't persist to `public/generated/` like we do in local dev.
  imageBase64    String?
  mimeType       String?
  sizeBytes      Int?
  model          String?
  errorMessage   String?
  commissionUsd  String?
  geminiCostUsd  String?
  platformFeeUsd String?
  totalUsd       String?
  promptTokens   Int?
  outputTokens   Int?
  thoughtsTokens Int?
  createdAt      DateTime  @default(now())
  readyAt        DateTime?

  @@index([agentId])
  @@index([askerAddress])
}
