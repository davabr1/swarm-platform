// Swarm schema — Supabase Postgres
// Mirrors the in-memory shape today (AgentListing, TaskPosting, activityLog)
// so route handlers stay thin and serializeAgent keeps working unchanged.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agent {
  id              String   @id
  name            String
  skill           String
  description     String
  price           String
  walletAddress   String
  creatorAddress  String?
  systemPrompt    String?
  type            String
  // For human rows (`type = "human_expert"`) only. Any non-empty subset of
  // ["expert", "completer"]. "expert" = verified specialist who takes
  // bounties gated with `Task.expertOnly`; "completer" = anyone who claims
  // the simpler real-world tasks. A single human can hold both roles.
  // Empty for non-human agents.
  roles           String[] @default([])
  userCreated     Boolean  @default(false)
  agentId         String?
  reputation      Float    @default(0)
  ratingsCount    Int      @default(0)
  totalCalls      Int      @default(0)
  pricingModel    String?
  pricingNote     String?
  createdAt       DateTime @default(now())

  @@unique([agentId])
  @@index([type])
  @@index([userCreated])
  @@index([reputation(sort: Desc)])
}

model Task {
  id             String    @id
  description    String
  bounty         String
  // Canonical numeric bounty in micro-USDC. Source of truth for balance
  // accounting; `bounty` (String) is kept for display + backwards compat.
  bountyMicroUsd BigInt    @default(0)
  skill          String
  payload        String?
  status         String    @default("open")
  postedBy       String?
  claimedBy      String?
  result         String?
  assignedTo     String?
  requiredSkill  String?
  minReputation  Float?
  // When true, only claimers with "expert" in Agent.roles may claim this
  // task. Default false = anyone with the skill (expert or completer) can.
  expertOnly     Boolean   @default(false)
  visibility     String    @default("private")
  posterRating   Int?
  posterRatedAt  DateTime?
  // Link back to the manual_spend Transaction that escrowed the bounty when
  // the task was posted. Null for legacy rows posted before Phase 3.
  escrowTransactionId String?
  // On-chain receipt when the bounty was paid out to the claimer at submit.
  payoutTxHash       String?
  payoutBlockNumber  Int?
  cancelledAt        DateTime?
  createdAt      DateTime  @default(now())
  claimedAt      DateTime?
  completedAt    DateTime?

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([assignedTo])
  @@index([requiredSkill])
}

model Activity {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  timestamp BigInt

  @@index([timestamp(sort: Desc)])
}

model UserProfile {
  walletAddress           String   @id
  displayName             String?
  bio                     String?
  email                   String?
  // DEPRECATED (x402 migration): pre-x402 deposited balance. No longer
  // read or written. Column retained for non-destructive migration;
  // drop after the hackathon.
  balanceMicroUsd         BigInt   @default(0)
  // DEPRECATED (x402 migration): pre-x402 autonomous-spend cap. No
  // longer read or written. Column retained for non-destructive
  // migration.
  autonomousCapUsd        String?
  // DEPRECATED (x402 migration): pre-x402 running spend counter. No
  // longer read or written. Column retained for non-destructive
  // migration.
  autonomousSpentMicroUsd BigInt   @default(0)
  // DEPRECATED (x402 migration): pre-x402 auto-topup flag. No longer
  // read or written. Column retained for non-destructive migration.
  autoTopup               Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// Append-only ledger powering the profile's Transactions panel. One row per
// balance delta (deposit credit, spend debit, earnings credit, refund).
model Transaction {
  id            String   @id @default(uuid())
  walletAddress String
  // "deposit" | "autonomous_spend" | "manual_spend" | "earning" | "refund"
  kind          String
  // Signed micro-USDC applied to this wallet (+ for deposit/earning/refund,
  // - for spend). Authoritative for the ledger; the UserProfile counter is
  // the cached sum.
  deltaMicroUsd BigInt
  // Absolute micro-USDC moved on-chain in the underlying transfer.
  grossMicroUsd BigInt
  description   String?
  // Cross-ref to the source row (guidance request / image gen / deposit).
  refType       String?
  refId         String?
  // On-chain tx hash. Null for pure-DB adjustments; unique-per-kind so
  // re-running the deposit scanner over the same block range can't double-
  // credit.
  txHash        String?
  blockNumber   Int?
  status        String   @default("confirmed")
  createdAt     DateTime @default(now())

  @@index([walletAddress, createdAt(sort: Desc)])
  @@index([kind])
  @@unique([txHash, kind], map: "Transaction_txHash_kind_key")
}

// DEPRECATED (x402 migration): pre-x402 deposit ledger. No reads or
// writes remain. Table retained for non-destructive migration; drop
// after the hackathon.
model Deposit {
  txHash        String   @id
  fromAddress   String
  microUsd      BigInt
  blockNumber   Int
  creditedAt    DateTime @default(now())
  transactionId String?

  @@index([fromAddress, creditedAt(sort: Desc)])
}

// DEPRECATED (x402 migration): pre-x402 deposit-scanner cursor. No
// reads or writes remain. Table retained for non-destructive migration.
model DepositScanCursor {
  id        String   @id
  lastBlock Int
  updatedAt DateTime @updatedAt
}

model GuidanceRequest {
  id                String    @id
  agentId           String
  askerAddress      String
  question          String
  status            String    @default("pending")
  response          String?
  errorMessage      String?
  commissionUsd     String?
  geminiCostUsd     String?
  platformFeeUsd    String?
  totalUsd          String?
  promptTokens      Int?
  outputTokens      Int?
  thoughtsTokens    Int?
  replyType         String?
  parentId          String?
  rootId            String?
  settlementTxHash  String?
  settlementStatus  String?   // "confirmed" | "simulated" | "failed" | "skipped"
  createdAt         DateTime  @default(now())
  readyAt           DateTime?

  @@index([agentId])
  @@index([askerAddress])
  @@index([rootId])
}

// DEPRECATED (x402 migration): pre-x402 pair-code handshake. The MCP
// now mints a local secp256k1 keypair and signs x402 per call — no
// server-side pair-code or session-token state exists. Tables retained
// for non-destructive migration; drop after the hackathon.
model PairCode {
  code       String   @id
  status     String
  sessionId  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// DEPRECATED (x402 migration): see PairCode comment.
model McpSession {
  id         String    @id @default(uuid())
  token      String    @unique
  address    String
  label      String?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([address])
  @@index([token])
}

model ImageGeneration {
  id                String    @id
  agentId           String
  askerAddress      String
  prompt            String
  status            String    @default("pending")
  imageUrl          String?
  // Base64-encoded PNG/JPEG bytes. Stored in Postgres so we can serve the
  // image via GET /api/image/[id] — Vercel's filesystem is read-only so we
  // can't persist to `public/generated/` like we do in local dev.
  imageBase64       String?
  mimeType          String?
  sizeBytes         Int?
  model             String?
  errorMessage      String?
  commissionUsd     String?
  geminiCostUsd     String?
  platformFeeUsd    String?
  totalUsd          String?
  promptTokens      Int?
  outputTokens      Int?
  thoughtsTokens    Int?
  settlementTxHash  String?
  settlementStatus  String?
  createdAt         DateTime  @default(now())
  readyAt           DateTime?

  @@index([agentId])
  @@index([askerAddress])
}
